# TradePulse Pro — Environment Configuration
# Copy this file to .env and fill in your credentials

# Market Preset: "us" | "nifty50" | "both" | "custom"
MARKET_PRESET=nifty50

# Broker Type: "paper" (default, no real money) | "zerodha" | "angel"
BROKER_TYPE=paper

# ─── Zerodha Kite Connect ───
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_USER_ID=
ZERODHA_TOTP_SECRET=

# ─── Angel One SmartAPI ───
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=
